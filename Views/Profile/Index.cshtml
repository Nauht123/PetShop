@model PetShop.ViewModels.ProfileVM
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5">
    <div class="row">

        @* Sidebar *@
        <div class="col-md-3">
            <div class="card shadow-sm mb-3">
                <div class="card-body text-center p-4">
                    <div style="font-size:4rem">👤</div>
                    <h6 class="fw-bold mt-2">@Model.HoTen</h6>
                    <small class="text-muted">@ViewBag.VaiTro</small>
                    <hr />
                    <div class="text-center">
                        <div class="fw-bold text-primary fs-4">
                            @ViewBag.DiemTichLuy
                        </div>
                        <small class="text-muted">Điểm tích lũy</small>
                    </div>
                    <hr />
                    <small class="text-muted">
                        Thành viên từ
                        @((DateTime)ViewBag.NgayTao)
                    </small>
                </div>
            </div>

            @* Menu *@
            <div class="list-group shadow-sm">
                <a asp-action="Index"
                   class="list-group-item list-group-item-action active">
                    👤 Thông tin cá nhân
                </a>
                <a asp-action="DoiMatKhau"
                   class="list-group-item list-group-item-action">
                    🔑 Đổi mật khẩu
                </a>
                <a asp-controller="Order" asp-action="MyOrders"
                   class="list-group-item list-group-item-action">
                    📦 Đơn hàng của tôi
                </a>
                <a asp-controller="Booking" asp-action="MyBookings"
                   class="list-group-item list-group-item-action">
                    📅 Lịch hẹn của tôi
                </a>
            </div>
        </div>

        @* Form thông tin *@
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <strong>👤 Thông tin cá nhân</strong>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            ✅ @TempData["Success"]
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        <input asp-for="Id" type="hidden" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="HoTen" class="form-label fw-bold">
                                    Họ tên
                                </label>
                                <input asp-for="HoTen" class="form-control" />
                                <span asp-validation-for="HoTen"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgaySinh" class="form-label fw-bold">
                                    Ngày sinh
                                </label>
                                <input asp-for="NgaySinh" type="date"
                                       class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">
                                    Email
                                </label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoDienThoai"
                                       class="form-label fw-bold">
                                    Số điện thoại
                                </label>
                                <input asp-for="SoDienThoai" class="form-control" />
                                <span asp-validation-for="SoDienThoai"
                                      class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi1" class="form-label fw-bold">
                                Địa chỉ giao hàng 1
                            </label>
                            <input asp-for="DiaChi1" class="form-control"
                                   placeholder="Số nhà, đường, phường, quận, tỉnh/thành" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi2" class="form-label fw-bold">
                                Địa chỉ giao hàng 2
                                <span class="text-muted fw-normal">(tùy chọn)</span>
                            </label>
                            <input asp-for="DiaChi2" class="form-control"
                                   placeholder="Địa chỉ thứ 2 (nơi làm việc,...)" />
                        </div>

                        <button type="submit" class="btn btn-primary px-4">
                            💾 Lưu thay đổi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>