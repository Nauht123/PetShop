@model PetShop.Helpers.PagedResult<object>
@{
    var routeValues = ViewData["RouteValues"] as Dictionary<string, string>
                       ?? new Dictionary<string, string>();
    var actionName = ViewData["ActionName"] as string ?? "Index";

    // Lấy tên Controller hiện tại từ RouteData — không cần truyền tay
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();

    string BuildUrl(int pageNum)
    {
        var routeDict = new Dictionary<string, string>(routeValues)
        {
            ["page"] = pageNum.ToString()
        };

        // Dùng Url.Action để sinh URL tuyệt đối, luôn đúng bất kể URL hiện tại
        return Url.Action(actionName, controllerName, routeDict) ?? "#";
    }
}

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <small class="text-muted">
            Trang @Model.CurrentPage / @Model.TotalPages
            (@Model.TotalItems kết quả)
        </small>

        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@BuildUrl(Model.CurrentPage - 1)">‹ Trước</a>
            </li>

            @{
                int startPage = Math.Max(1, Model.CurrentPage - 2);
                int endPage = Math.Min(Model.TotalPages, startPage + 4);
                startPage = Math.Max(1, endPage - 4);
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="@BuildUrl(i)">@i</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@BuildUrl(Model.CurrentPage + 1)">Sau ›</a>
            </li>
        </ul>
    </nav>
}