@{
    ViewData["Title"] = "Giới thiệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <div style="font-size:8rem; text-align:center">🐾</div>
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold">Về PetShop</h2>
            <p class="text-muted mt-3">
                PetShop là cửa hàng chuyên cung cấp thức ăn và phụ kiện
                cho thú cưng với chất lượng cao, giá cả hợp lý.
            </p>
            <p class="text-muted">
                Chúng tôi cam kết mang đến sản phẩm chính hãng,
                dịch vụ chăm sóc chuyên nghiệp và trải nghiệm mua sắm
                tốt nhất cho khách hàng.
            </p>
            <div class="row mt-4">
                <div class="col-4 text-center">
                    <h3 class="text-primary fw-bold">500+</h3>
                    <small class="text-muted">Sản phẩm</small>
                </div>
                <div class="col-4 text-center">
                    <h3 class="text-primary fw-bold">1000+</h3>
                    <small class="text-muted">Khách hàng</small>
                </div>
                <div class="col-4 text-center">
                    <h3 class="text-primary fw-bold">5⭐</h3>
                    <small class="text-muted">Đánh giá</small>
                </div>
            </div>
        </div>
    </div>
</div>