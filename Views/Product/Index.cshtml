@model List<PetShop.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using PetShop.Models
@{
    var ratingDict = ViewBag.RatingDict
        as Dictionary<int, RatingInfo>
        ?? new Dictionary<int, RatingInfo>();
}

<div class="container mt-4">
    <div class="row">

        @* CỘT TRÁI: Bộ lọc danh mục *@
        <div class="col-md-3">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white">
                    <strong>🗂️ Danh mục</strong>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index"
                       class="list-group-item list-group-item-action @(ViewBag.CurrentCategory == null ? "active" : "")">
                        Tất cả sản phẩm
                    </a>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <a asp-action="Index" asp-route-categoryId="@cat.Id"
                           class="list-group-item list-group-item-action @(ViewBag.CurrentCategory == cat.Id ? "active" : "")">
                            @cat.TenDanhMuc
                        </a>
                    }
                </div>
            </div>
        </div>

        @* CỘT PHẢI: Danh sách sản phẩm *@
        <div class="col-md-9">

            @* Thanh tìm kiếm *@
            <form asp-action="Index" method="get" class="mb-3">
                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.CurrentSearch"
                           class="form-control" placeholder="Tìm kiếm sản phẩm..." />
                    <button class="btn btn-primary" type="submit">🔍 Tìm</button>
                    @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">✕ Xóa</a>
                    }
                </div>
            </form>

            @* Grid sản phẩm *@
            @if (!Model.Any())
            {
                <div class="alert alert-info">Không tìm thấy sản phẩm nào.</div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <a asp-action="Detail" asp-route-id="@item.Id">
                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                    {
                                        <img src="@item.HinhAnh" class="card-img-top"
                                             style="height:200px; object-fit:cover" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center
                                                                justify-content-center"
                                             style="height:200px; font-size:3rem">
                                            🐾
                                        </div>
                                    }
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <small class="text-muted">@item.Category?.TenDanhMuc</small>
                                    <h6 class="card-title mt-1">
                                        <a asp-action="Detail" asp-route-id="@item.Id"
                                           class="text-decoration-none text-dark">
                                            @item.TenSanPham
                                        </a>
                                    </h6>
                                    @* ── RATING ── *@
                                    @if (ratingDict.ContainsKey(item.Id))
                                    {
                                        var r = ratingDict[item.Id];
                                        <div style="color:#f59e0b; font-size:12px">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                @(i <= (int)Math.Round(r.Avg) ? "★" : "☆")
                                            }
                                            <span class="text-muted ms-1">(@r.Count)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="color:#ddd; font-size:12px">
                                            ☆☆☆☆☆
                                            <span class="text-muted ms-1">(0)</span>
                                        </div>
                                    }

                                    <p class="text-danger fw-bold mt-auto mb-2">
                                        @item.Gia.ToString("N0") đ
                                    </p>
                                    <a asp-controller="Cart" asp-action="Add"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary btn-sm w-100">
                                        🛒 Thêm vào giỏ
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Phân trang *@
                @if (ViewBag.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-categoryId="@ViewBag.CurrentCategory"
                                       asp-route-search="@ViewBag.CurrentSearch">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>