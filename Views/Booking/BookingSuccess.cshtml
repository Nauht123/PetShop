@{
    ViewData["Title"] = "Đặt lịch thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow p-5">
                <div style="font-size:5rem">🎉</div>
                <h3 class="mt-3 text-success">Đặt lịch thành công!</h3>
                <p class="text-muted mt-2">
                    Mã lịch hẹn: <strong>#@ViewBag.BookingId</strong>
                </p>
                <p class="text-muted">
                    Chúng tôi sẽ liên hệ xác nhận lịch hẹn của bạn sớm nhất.<br />
                    Vui lòng đến đúng giờ đã đặt.
                </p>
                <hr />
                <div class="d-flex gap-2 justify-content-center mt-2">
                    <a asp-controller="Booking" asp-action="MyBookings"
                       class="btn btn-primary">
                        📅 Lịch hẹn của tôi
                    </a>
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary">
                        🏠 Về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>