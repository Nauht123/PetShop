@{
    ViewData["Title"] = "Chính sách đổi trả";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-4">
                <div style="font-size:3rem">🔄</div>
                <h2 class="fw-bold mt-2">Chính sách đổi trả dễ dàng</h2>
                <p class="text-muted">Đổi trả trong vòng 7 ngày, thủ tục đơn giản</p>
            </div>

            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3">📅 Thời hạn đổi trả</h5>
                <p>Khách hàng được đổi trả sản phẩm trong vòng <strong>7 ngày</strong> kể từ ngày nhận hàng.</p>

                <h5 class="fw-bold mb-3 mt-4">✔️ Điều kiện đổi trả</h5>
                <ul>
                    <li>Sản phẩm còn nguyên tem, nhãn, bao bì chưa qua sử dụng</li>
                    <li>Có hóa đơn mua hàng hoặc mã đơn hàng</li>
                    <li>Sản phẩm bị lỗi do nhà sản xuất, giao sai mẫu mã, sai số lượng</li>
                </ul>

                <h5 class="fw-bold mb-3 mt-4">❌ Trường hợp không áp dụng</h5>
                <ul>
                    <li>Sản phẩm đã qua sử dụng, hư hỏng do lỗi người dùng</li>
                    <li>Thức ăn, thực phẩm đã mở bao bì (trừ trường hợp lỗi từ nhà sản xuất)</li>
                </ul>

                <h5 class="fw-bold mb-3 mt-4">📋 Quy trình đổi trả</h5>
                <ol>
                    <li>Liên hệ hotline hoặc email để thông báo yêu cầu đổi trả</li>
                    <li>Gửi sản phẩm về địa chỉ cửa hàng hoặc theo hướng dẫn của nhân viên hỗ trợ</li>
                    <li>PetShop kiểm tra và xử lý đổi trả/hoàn tiền trong vòng 3 - 5 ngày làm việc</li>
                </ol>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">← Quay lại trang chủ</a>
            </div>
        </div>
    </div>
</div>