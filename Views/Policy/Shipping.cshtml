@{
    ViewData["Title"] = "Chính sách giao hàng";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-4">
                <div style="font-size:3rem">🚚</div>
                <h2 class="fw-bold mt-2">Chính sách giao hàng toàn quốc</h2>
                <p class="text-muted">Giao hàng nhanh chóng, an toàn đến mọi miền đất nước</p>
            </div>

            <div class="card shadow-sm p-4">
                <h5 class="fw-bold mb-3">📦 Phạm vi giao hàng</h5>
                <p>PetShop giao hàng trên toàn quốc, phủ khắp 63 tỉnh thành. Đơn hàng sẽ được vận chuyển qua các đối tác giao vận uy tín để đảm bảo thời gian và chất lượng.</p>

                <h5 class="fw-bold mb-3 mt-4">⏱️ Thời gian giao hàng</h5>
                <ul>
                    <li>Nội thành TP.HCM & Hà Nội: 1 - 2 ngày làm việc</li>
                    <li>Các tỉnh thành khác: 3 - 5 ngày làm việc</li>
                    <li>Khu vực vùng sâu, vùng xa: 5 - 7 ngày làm việc</li>
                </ul>

                <h5 class="fw-bold mb-3 mt-4">💰 Phí vận chuyển</h5>
                <ul>
                    <li>Miễn phí vận chuyển cho đơn hàng từ 300.000đ</li>
                    <li>Đơn hàng dưới 300.000đ: phí ship tính theo khu vực, hiển thị cụ thể tại bước thanh toán</li>
                </ul>

                <h5 class="fw-bold mb-3 mt-4">📞 Hỗ trợ</h5>
                <p>Nếu đơn hàng gặp sự cố trong quá trình vận chuyển, vui lòng liên hệ hotline <strong>0937 131 914</strong> để được hỗ trợ nhanh nhất.</p>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">← Quay lại trang chủ</a>
            </div>
        </div>
    </div>
</div>