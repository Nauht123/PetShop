@model List<PetShop.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5">
    <h4 class="mb-4">📦 Đơn hàng của tôi</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:4rem">📭</div>
            <h5 class="text-muted mt-3">Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Product" asp-action="Index"
               class="btn btn-primary mt-3">Mua sắm ngay →</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            @* Badge màu theo trạng thái *@
            var badgeClass = order.TrangThai switch
            {
                "ChoXacNhan" => "bg-warning text-dark",
                "DangGiao" => "bg-info text-dark",
                "HoanThanh" => "bg-success",
                "DaHuy" => "bg-danger",
                _ => "bg-secondary"
            };

            var badgeText = order.TrangThai switch
            {
                "ChoXacNhan" => "⏳ Chờ xác nhận",
                "DangGiao" => "🚚 Đang giao",
                "HoanThanh" => "✅ Hoàn thành",
                "DaHuy" => "❌ Đã hủy",
                _ => order.TrangThai
            };

            <div class="card shadow-sm mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>
                        <strong>Đơn hàng #@order.Id</strong>
                        <span class="text-muted ms-2" style="font-size:13px">
                            @order.NgayDat.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </span>
                    <span class="badge @badgeClass">@badgeText</span>
                </div>
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div style="font-size:13px; color:#666">
                            📍 @order.DiaChiGiao
                        </div>
                        <div class="text-danger fw-bold mt-1">
                            @order.TongTien.ToString("N0") đ
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Detail" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-primary">
                            Xem chi tiết
                        </a>
                        @if (order.TrangThai == "ChoXacNhan")
                        {
                            <form asp-action="Cancel" asp-route-id="@order.Id"
                                  method="post"
                                  onsubmit="return confirm('Hủy đơn hàng này?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Hủy đơn
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>