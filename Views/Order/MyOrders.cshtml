@model List<PetShop.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5">
    <h4 class="mb-4">📦 Đơn hàng của tôi</h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* Bộ lọc *@
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="MyOrders" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold small">Từ ngày</label>
                        <input type="date" name="tuNgay"
                               value="@ViewBag.TuNgay"
                               class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small">Đến ngày</label>
                        <input type="date" name="denNgay"
                               value="@ViewBag.DenNgay"
                               class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small">Trạng thái</label>
                        <select name="trangThai" class="form-select">
                            <option value="">-- Tất cả --</option>
                            <option value="ChoXacNhan"
                                    selected="@(ViewBag.TrangThai == "ChoXacNhan")">
                                ⏳ Chờ xác nhận
                            </option>
                            <option value="DangGiao"
                                    selected="@(ViewBag.TrangThai == "DangGiao")">
                                🚚 Đang giao
                            </option>
                            <option value="HoanThanh"
                                    selected="@(ViewBag.TrangThai == "HoanThanh")">
                                ✅ Hoàn thành
                            </option>
                            <option value="DaHuy"
                                    selected="@(ViewBag.TrangThai == "DaHuy")">
                                ❌ Đã hủy
                            </option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            🔍 Lọc
                        </button>
                        <a asp-action="MyOrders"
                           class="btn btn-outline-secondary">
                            ✕
                        </a>
                    </div>
                </div>

                @* Lọc nhanh *@
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-action="MyOrders"
                       asp-route-tuNgay="@DateTime.Today.ToString("yyyy-MM-dd")"
                       asp-route-denNgay="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-outline-secondary">
                        Hôm nay
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-tuNgay="@DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd")"
                       asp-route-denNgay="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-outline-secondary">
                        7 ngày qua
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-tuNgay="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")"
                       asp-route-denNgay="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-outline-secondary">
                        30 ngày qua
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-tuNgay="@(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).ToString("yyyy-MM-dd"))"
                       asp-route-denNgay="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-sm btn-outline-secondary">
                        Tháng này
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-trangThai="ChoXacNhan"
                       class="btn btn-sm btn-outline-warning">
                        ⏳ Chờ xác nhận
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-trangThai="DangGiao"
                       class="btn btn-sm btn-outline-info">
                        🚚 Đang giao
                    </a>
                    <a asp-action="MyOrders"
                       asp-route-trangThai="HoanThanh"
                       class="btn btn-sm btn-outline-success">
                        ✅ Hoàn thành
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Kết quả *@
    @if (ViewBag.TuNgay != null || ViewBag.DenNgay != null || ViewBag.TrangThai != null)
    {
        <div class="alert alert-info py-2 mb-3">
            🔍 Tìm thấy <strong>@ViewBag.TongDon</strong> đơn hàng
            @if (ViewBag.TuNgay != null || ViewBag.DenNgay != null)
            {
                <span>
                    từ <strong>@(ViewBag.TuNgay ?? "đầu")</strong>
                    đến <strong>@(ViewBag.DenNgay ?? "nay")</strong>
                </span>
            }
            @if (ViewBag.TrangThai != null)
            {
                <span>• Trạng thái: <strong>@ViewBag.TrangThai</strong></span>
            }
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:4rem">📭</div>
            <h5 class="text-muted mt-3">Không có đơn hàng nào</h5>
            <a asp-controller="Product" asp-action="Index"
               class="btn btn-primary mt-3">
                Mua sắm ngay →
            </a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            var badgeClass = order.TrangThai switch
            {
                "ChoXacNhan" => "bg-warning text-dark",
                "DangGiao" => "bg-info text-dark",
                "HoanThanh" => "bg-success",
                "DaHuy" => "bg-danger",
                _ => "bg-secondary"
            };

            var badgeText = order.TrangThai switch
            {
                "ChoXacNhan" => "⏳ Chờ xác nhận",
                "DangGiao" => "🚚 Đang giao",
                "HoanThanh" => "✅ Hoàn thành",
                "DaHuy" => "❌ Đã hủy",
                _ => order.TrangThai
            };

            <div class="card shadow-sm mb-3">
                <div class="card-header d-flex justify-content-between
                                    align-items-center">
                    <span>
                        <strong>Đơn hàng #@order.Id</strong>
                        <span class="text-muted ms-2" style="font-size:13px">
                            @order.NgayDat.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </span>
                    <span class="badge @badgeClass">@badgeText</span>
                </div>
                <div class="card-body d-flex justify-content-between
                                    align-items-center flex-wrap gap-2">
                    <div>
                        <div style="font-size:13px; color:#666">
                            📍 @order.DiaChiGiao
                        </div>
                        <div class="text-danger fw-bold mt-1">
                            @order.TongTien.ToString("N0") đ
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Detail" asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-primary">
                            Xem chi tiết
                        </a>
                        @if (order.TrangThai == "ChoXacNhan")
                        {
                            <form asp-action="Cancel" asp-route-id="@order.Id"
                                  method="post"
                                  onsubmit="return confirm('Hủy đơn hàng này?')">
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger">
                                    Hủy đơn
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>