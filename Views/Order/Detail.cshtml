@model PetShop.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var badgeClass = Model.TrangThai switch
    {
        "ChoXacNhan" => "bg-warning text-dark",
        "DangGiao" => "bg-info text-dark",
        "HoanThanh" => "bg-success",
        "DaHuy" => "bg-danger",
        _ => "bg-secondary"
    };

    var badgeText = Model.TrangThai switch
    {
        "ChoXacNhan" => "⏳ Chờ xác nhận",
        "DangGiao" => "🚚 Đang giao",
        "HoanThanh" => "✅ Hoàn thành",
        "DaHuy" => "❌ Đã hủy",
        _ => Model.TrangThai
    };
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4>📦 Chi tiết đơn hàng #@Model.Id</h4>
        <span class="badge @badgeClass fs-6">@badgeText</span>
    </div>

    <div class="row">

        @* Thông tin đơn hàng *@
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <strong>📍 Thông tin giao hàng</strong>
                </div>
                <div class="card-body" style="font-size:14px">
                    <p class="mb-1">@Model.DiaChiGiao</p>
                    <hr />
                    <p class="mb-1">
                        <strong>Ngày đặt:</strong>
                        @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")
                    </p>
                    <p class="mb-1">
                        <strong>Thanh toán:</strong> COD (khi nhận hàng)
                    </p>
                </div>
            </div>
        </div>

        @* Danh sách sản phẩm *@
        <div class="col-md-8 mb-3">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <strong>🛒 Sản phẩm</strong>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(d.Product?.HinhAnh))
                                            {
                                                <img src="@d.Product.HinhAnh"
                                                     width="45" height="45"
                                                     style="object-fit:cover"
                                                     class="rounded" />
                                            }
                                            <span style="font-size:13px">
                                                @d.Product?.TenSanPham
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @d.DonGia.ToString("N0") đ
                                    </td>
                                    <td class="text-center">@d.SoLuong</td>
                                    <td class="text-end text-danger fw-bold">
                                        @((d.DonGia * d.SoLuong).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">
                                    Tổng cộng:
                                </td>
                                <td class="text-end text-danger fw-bold fs-5">
                                    @Model.TongTien.ToString("N0") đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <a asp-action="MyOrders"
               class="btn btn-outline-secondary mt-3">
                ← Quay lại danh sách đơn hàng
            </a>
            @* ── ĐÁNH GIÁ SẢN PHẨM (chỉ hiện khi đơn đã Hoàn thành) ── *@
            @if (Model.TrangThai == "HoanThanh")
            {
                var reviewedIds = ViewBag.ReviewedProductIds as HashSet<int>
                ?? new HashSet<int>();

                <div class="mt-4">
                    <h5 class="mb-3">⭐ Đánh giá sản phẩm đã mua</h5>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    @foreach (var d in Model.OrderDetails)
                    {
                        bool daDanhGia = reviewedIds.Contains(d.ProductId);

                        <div class="card shadow-sm mb-3">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    @if (!string.IsNullOrEmpty(d.Product?.HinhAnh))
                                    {
                                        <img src="@d.Product.HinhAnh" width="45" height="45"
                                             style="object-fit:cover" class="rounded" />
                                    }
                                    <span class="fw-bold" style="font-size:14px">
                                        @d.Product?.TenSanPham
                                    </span>
                                </div>

                                @if (daDanhGia)
                                {
                                    <div class="alert alert-info py-2 mb-0" style="font-size:13px">
                                        ✅ Bạn đã đánh giá sản phẩm này.
                                        <a asp-controller="Product" asp-action="Detail"
                                           asp-route-id="@d.ProductId"
                                           class="fw-bold ms-1">Xem đánh giá →</a>
                                    </div>
                                }
                                else
                                {
                                    <form asp-controller="Review" asp-action="Submit"
                                          method="post" class="mt-2">
                                        <input type="hidden" name="ProductId" value="@d.ProductId" />

                                        <div class="mb-2">
                                            <label class="form-label small fw-bold">Số sao</label>
                                            <div class="d-flex gap-2 star-rating-order-@d.ProductId">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <div class="form-check form-check-inline">
                                                        <input class="form-check-input d-none"
                                                               type="radio" name="SoSao"
                                                               id="star_@(d.ProductId)_@i" value="@i" />
                                                        <label class="form-check-label star-label-order"
                                                               for="star_@(d.ProductId)_@i"
                                                               data-group="star-rating-order-@d.ProductId"
                                                               style="font-size:1.6rem; cursor:pointer; color:#ddd">
                                                            ★
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="mb-2">
                                            <textarea name="NoiDung" class="form-control" rows="2"
                                          placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm (tối thiểu 10 ký tự)..."></textarea>
                                        </div>

                                        <button type="submit" class="btn btn-warning btn-sm fw-bold">
                                            ⭐ Gửi đánh giá
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>
@section Scripts {
    <script>
        // Xử lý hiệu ứng chọn sao cho TỪNG sản phẩm riêng biệt trong trang
        document.querySelectorAll('.star-label-order').forEach(label => {
            label.addEventListener('mouseover', function () {
                const group = this.dataset.group;
                const labels = document.querySelectorAll(
                    `.star-label-order[data-group="${group}"]`);
                const index = Array.from(labels).indexOf(this);

                labels.forEach((l, i) => {
                    l.style.color = i <= index ? '#f59e0b' : '#ddd';
                });
            });

            label.addEventListener('mouseout', function () {
                const group = this.dataset.group;
                const labels = document.querySelectorAll(
                    `.star-label-order[data-group="${group}"]`);
                const checkedInput = document.querySelector(
                    `input[name="SoSao"]:checked`);

                // Chỉ reset nếu input được check không thuộc group này
                const checkedIndex = checkedInput &&
                    checkedInput.id.includes(group.replace('star-rating-order-', 'star_') + '_')
                    ? parseInt(checkedInput.value) - 1 : -1;

                labels.forEach((l, i) => {
                    l.style.color = i <= checkedIndex ? '#f59e0b' : '#ddd';
                });
            });

            label.addEventListener('click', function () {
                const group = this.dataset.group;
                const labels = document.querySelectorAll(
                    `.star-label-order[data-group="${group}"]`);
                const index = Array.from(labels).indexOf(this);

                labels.forEach((l, i) => {
                    l.style.color = i <= index ? '#f59e0b' : '#ddd';
                });
            });
        });
    </script>
}