@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow p-5">
                <div style="font-size:5rem">✅</div>
                <h3 class="mt-3 text-success">Đặt hàng thành công!</h3>
                <p class="text-muted mt-2">
                    Mã đơn hàng: <strong>#@ViewBag.OrderId</strong>
                </p>
                <p class="text-muted">
                    Cảm ơn bạn đã mua hàng tại PetShop!<br />
                    Chúng tôi sẽ liên hệ xác nhận đơn hàng sớm nhất.
                </p>
                <hr />
                <div class="d-flex gap-2 justify-content-center mt-2">
                    <a asp-controller="Order" asp-action="MyOrders"
                       class="btn btn-primary">
                        📦 Xem đơn hàng của tôi
                    </a>
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-secondary">
                        🏠 Về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>