@model List<PetShop.Models.Booking>
@{
    ViewData["Title"] = "Quản lý Lịch hẹn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h3 class="mb-3">📅 Quản lý Lịch hẹn</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @* Lọc trạng thái *@
    <div class="d-flex gap-2 mb-3 flex-wrap">
        @foreach (var tt in new[]
                {
                ("", "Tất cả"),
                ("ChoXacNhan", "⏳ Chờ xác nhận"),
                ("DaXacNhan",  "✅ Đã xác nhận"),
                ("HoanThanh",  "🎉 Hoàn thành"),
                ("DaHuy",      "❌ Đã hủy")
                })
        {
            <a asp-action="Index" asp-route-trangThai="@tt.Item1"
               class="btn btn-sm @(ViewBag.TrangThai == tt.Item1
                                  || (ViewBag.TrangThai == null && tt.Item1 == "")
                                  ? "btn-primary" : "btn-outline-secondary")">
            @tt.Item2
        </a>
                }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Khách hàng</th>
                        <th>Dịch vụ</th>
                        <th>Ngày hẹn</th>
                        <th>Giờ</th>
                        <th>Ghi chú</th>
                        <th>Trạng thái</th>
                        <th>Cập nhật</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        var bc = b.TrangThai switch
                        {
                            "ChoXacNhan" => "badge bg-warning text-dark",
                            "DaXacNhan" => "badge bg-info text-dark",
                            "HoanThanh" => "badge bg-success",
                            "DaHuy" => "badge bg-danger",
                            _ => "badge bg-secondary"
                        };

                        <tr>
                            <td><strong>#@b.Id</strong></td>
                            <td>
                                <div>@b.User?.HoTen</div>
                                <small class="text-muted">
                                    @b.User?.SoDienThoai
                                </small>
                            </td>
                            <td>
                                <div>@b.Service?.TenDichVu</div>
                                <small class="text-danger">
                                    @b.Service?.Gia.ToString("N0") đ
                                </small>
                            </td>
                            <td>@b.NgayHen.ToString("dd/MM/yyyy")</td>
                            <td>@b.GioHen</td>
                            <td style="font-size:12px; max-width:150px">
                                @b.GhiChu
                            </td>
                            <td>
                                <span class="@bc">@b.TrangThai</span>
                            </td>
                            <td>
                                <form asp-action="UpdateStatus" method="post"
                                      class="d-flex gap-1">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <select name="trangThai"
                                            class="form-select form-select-sm"
                                            style="width:140px">
                                        <option value="ChoXacNhan"
                                                selected="@(b.TrangThai == "ChoXacNhan")">
                                            Chờ xác nhận
                                        </option>
                                        <option value="DaXacNhan"
                                                selected="@(b.TrangThai == "DaXacNhan")">
                                            Đã xác nhận
                                        </option>
                                        <option value="HoanThanh"
                                                selected="@(b.TrangThai == "HoanThanh")">
                                            Hoàn thành
                                        </option>
                                        <option value="DaHuy"
                                                selected="@(b.TrangThai == "DaHuy")">
                                            Đã hủy
                                        </option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary">
                                        Lưu
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                Không có lịch hẹn nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>