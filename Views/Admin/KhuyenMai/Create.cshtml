@model PetShop.Models.KhuyenMai
@{
    ViewData["Title"] = "Tạo Mã Khuyến mãi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🎟️ Tạo Mã Khuyến mãi mới</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaCode" class="form-label fw-bold">
                                    Mã code
                                </label>
                                <input asp-for="MaCode" class="form-control"
                                       placeholder="VD: SUMMER20"
                                       style="text-transform:uppercase" />
                                <span asp-validation-for="MaCode"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuong" class="form-label fw-bold">
                                    Số lượt dùng
                                </label>
                                <input asp-for="SoLuong" type="number"
                                       class="form-control" min="1" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label fw-bold">
                                Mô tả
                            </label>
                            <input asp-for="MoTa" class="form-control"
                                   placeholder="VD: Giảm 20% cho đơn từ 100.000đ" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="LoaiGiam" class="form-label fw-bold">
                                    Loại giảm
                                </label>
                                <select asp-for="LoaiGiam" class="form-select">
                                    <option value="1">% Phần trăm</option>
                                    <option value="2">đ Số tiền cố định</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GiaTriGiam" class="form-label fw-bold">
                                    Giá trị giảm
                                </label>
                                <input asp-for="GiaTriGiam" type="number"
                                       class="form-control" min="0" />
                                <small class="text-muted">
                                    Nhập 20 nếu giảm 20%, hoặc 50000 nếu giảm 50.000đ
                                </small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DonHangToiThieu"
                                       class="form-label fw-bold">
                                    Đơn hàng tối thiểu (đ)
                                </label>
                                <input asp-for="DonHangToiThieu" type="number"
                                       class="form-control" min="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="GiamToiDa" class="form-label fw-bold">
                                    Giảm tối đa (đ)
                                </label>
                                <input asp-for="GiamToiDa" type="number"
                                       class="form-control" min="0" />
                                <small class="text-muted">
                                    Áp dụng khi giảm theo %, 0 = không giới hạn
                                </small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgayBatDau" class="form-label fw-bold">
                                    Ngày bắt đầu
                                </label>
                                <input asp-for="NgayBatDau" type="date"
                                       class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NgayKetThuc"
                                       class="form-label fw-bold">
                                    Ngày kết thúc
                                </label>
                                <input asp-for="NgayKetThuc" type="date"
                                       class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsActive"
                                       class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">
                                    Kích hoạt ngay
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                💾 Tạo mã
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>