@model List<PetShop.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🗂️ Quản lý Danh mục</h3>
        <a asp-controller="AdminCategory" asp-action="Create"
           class="btn btn-primary">+ Thêm danh mục</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên danh mục</th>
                <th>Mô tả</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.TenDanhMuc</td>
                    <td>@item.MoTa</td>
                    <td>
                        <a asp-controller="AdminCategory" asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">Sửa</a>

                        <form asp-controller="AdminCategory" asp-action="Delete"
                              asp-route-id="@item.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa danh mục này?')">
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">Chưa có danh mục nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>