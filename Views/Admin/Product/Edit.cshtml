@model PetShop.Models.Product
@{
    ViewData["Title"] = "Sửa Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">✏️ Sửa Sản phẩm</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input asp-for="Id" type="hidden" />
                        <input asp-for="HinhAnh" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="TenSanPham" class="form-label">Tên sản phẩm</label>
                            <input asp-for="TenSanPham" class="form-control" />
                            <span asp-validation-for="TenSanPham" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label">Mô tả</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gia" class="form-label">Giá (đ)</label>
                                <input asp-for="Gia" class="form-control" type="number" min="0" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuongKho" class="form-label">Số lượng kho</label>
                                <input asp-for="SoLuongKho" class="form-control" type="number" min="0" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories"
                                    class="form-select"></select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hình ảnh hiện tại</label><br />
                            @if (!string.IsNullOrEmpty(Model.HinhAnh))
                            {
                                <img src="@Model.HinhAnh" width="100" class="rounded mb-2" />
                            }
                            else
                            {
                                <span class="text-muted">Chưa có ảnh</span>
                            }
                            <input type="file" name="imageFile" class="form-control mt-2"
                                   accept="image/*" />
                            <small class="text-muted">Để trống nếu không muốn đổi ảnh</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Trạng thái hiển thị</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input asp-for="IsHot" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsHot" class="form-check-label">
                                        🔥 Hàng Hot
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="IsBanChay" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsBanChay" class="form-check-label">
                                        ⚡ Bán chạy
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Cập nhật</button>
                            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>