@model PetShop.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">🔑 Đặt lại mật khẩu</h4>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form asp-action="ResetPassword" method="post">
                        <input type="hidden" asp-for="Token" />

                        <div class="mb-3">
                            <label asp-for="MatKhauMoi" class="form-label">Mật khẩu mới</label>
                            <input asp-for="MatKhauMoi" type="password" class="form-control" />
                            <span asp-validation-for="MatKhauMoi" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="XacNhanMatKhau" class="form-label">Xác nhận mật khẩu</label>
                            <input asp-for="XacNhanMatKhau" type="password" class="form-control" />
                            <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2 small"></div>

                        <button type="submit" class="btn btn-primary w-100">
                            Xác nhận đặt lại mật khẩu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>